{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(*.env)",
      "Read(*.env.local)",
      "Read(*.env.development*)",
      "Read(*.env.production*)",
      "Read(*.env.test*)",
      "Edit(*.env)",
      "Edit(*.env.local)",
      "Edit(*.env.development*)",
      "Edit(*.env.production*)",
      "Edit(*.env.test*)",
      "Bash(* .env)",
      "Bash(* .env.local)",
      "Bash(* .env.development*)",
      "Bash(* .env.production*)",
      "Bash(* .env.test*)"
    ]
  },
  "sandbox": {
    "enabled": true
  }
}
