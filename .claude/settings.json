{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": ["Read(.env.example)", "Edit(.env.example)"],
    "deny": [
      "Read(*.env)",
      "Read(*.env.*)",
      "Edit(*.env)",
      "Edit(*.env.*)",
      "Bash(* .env)",
      "Bash(* .env.*)"
    ]
  },
  "sandbox": {
    "enabled": true
  }
}
